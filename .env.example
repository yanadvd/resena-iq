# ============================================================================
#  ReseñaIQ — Variables de entorno
#  Copia este archivo a .env y rellena los valores.
#  cp .env.example .env
# ============================================================================

# ----------------------------------------------------------------------------
# Base de datos (PostgreSQL).
# - DATABASE_URL: conexión con pooling (PgBouncer) — la usa la app en runtime.
# - DIRECT_URL:   conexión directa (sin pooling) — la usan las migraciones.
# En local, ambas pueden ser idénticas. En Supabase/Neon (producción serverless):
#   DATABASE_URL = la "Connection pooling" (puerto 6543, con ?pgbouncer=true)
#   DIRECT_URL   = la "Direct connection"  (puerto 5432)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/resenaiq?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/resenaiq?schema=public"

# ----------------------------------------------------------------------------
# NextAuth — autenticación
# Genera un secret con:  openssl rand -base64 32
# ----------------------------------------------------------------------------
NEXTAUTH_SECRET="reemplaza-con-un-secret-aleatorio-largo"
NEXTAUTH_URL="http://localhost:3000"

# OAuth con Google (Google Cloud Console > Credenciales > OAuth 2.0)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ----------------------------------------------------------------------------
# Stripe — pagos y suscripciones
# Dashboard de Stripe > Developers > API keys
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Secret del endpoint de webhooks. Lo obtienes al crear el webhook o con la CLI:
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs de los planes (Stripe > Products > selecciona producto > Price ID).
# Crea 2 productos (Pro y Business) con precios mensuales recurrentes.
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_BUSINESS="price_..."

# ----------------------------------------------------------------------------
# OpenAI — análisis de sentimiento y resúmenes con IA
# Si se deja vacío, la app usa un analizador heurístico local (modo demo).
# ----------------------------------------------------------------------------
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ----------------------------------------------------------------------------
# Integraciones de reseñas
# Google Places API — conector real de Google Reviews. Habilita "Places API"
# en Google Cloud (+ billing). El Place ID de cada negocio se configura por
# fuente al conectarla en el dashboard. Si se deja vacío, Google usa datos demo.
# ----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=""
# Yelp Fusion API — conector de Yelp. Crea una app en https://www.yelp.com/developers
# El Business ID/alias de cada negocio se configura por fuente en el dashboard.
# Límite de Yelp: 3 reseñas con texto truncado. Vacío = datos demo.
YELP_API_KEY=""

# ----------------------------------------------------------------------------
# Email — alertas (Resend). Si se deja vacío, las alertas se loguean en consola.
# ----------------------------------------------------------------------------
RESEND_API_KEY=""
ALERTS_FROM_EMAIL="alertas@tudominio.com"

# ----------------------------------------------------------------------------
# Email PROMOCIONAL / marketing (Brevo) — SEPARADO de Resend (transaccional).
# Los contactos que dan su consentimiento (opt-in) se sincronizan a una lista
# de Brevo; las campañas se envían desde el panel de Brevo. Vacío = no sincroniza.
# ----------------------------------------------------------------------------
BREVO_API_KEY=""
BREVO_LIST_ID=""

# ----------------------------------------------------------------------------
# Automatización / Cron
# Token para proteger el endpoint /api/cron/sync (Vercel Cron o llamada externa).
# ----------------------------------------------------------------------------
CRON_SECRET="reemplaza-con-un-token-secreto"

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
